# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Discord webhook (optional; unused if Gmail alerts are preferred)
DISCORD_WEBHOOK_URL=

# Gmail alert settings
# GMAIL_APP_PASSWORD: 16-char app password issued from Google Account -> App passwords
GMAIL_USER=
GMAIL_APP_PASSWORD=
ALERT_RECEIVER=
