GEMINI_API_KEY=your_api_key_here

# Ollama ホスト（ローカル直接実行: http://localhost:11434 / Docker内: http://host.docker.internal:11434）
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
SPREADSHEET_ID=your_spreadsheet_id_here

# Gmail アラート設定
# GMAIL_APP_PASSWORD: Google アカウント → セキュリティ → アプリパスワード で発行した 16 文字
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16char_app_password
ALERT_RECEIVER=receiver@example.com