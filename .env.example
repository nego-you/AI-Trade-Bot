# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Gmail alert settings
# GMAIL_APP_PASSWORD: 16-char app password issued from Google Account -> App passwords
GMAIL_USER=
GMAIL_APP_PASSWORD=
ALERT_RECEIVER=

# Google Spreadsheet logging (see docs/06_spreadsheet_setup.md)
# Path to the GCP service account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=
# Spreadsheet ID (the long string in the sheet URL)
SPREADSHEET_ID=
